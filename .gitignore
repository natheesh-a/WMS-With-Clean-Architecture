```gitignore
############################################################
# Build Results
############################################################

[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
publish/
artifacts/

############################################################
# Visual Studio
############################################################

.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.cache
*.pdb
*.VC.db
*.VC.opendb

############################################################
# Visual Studio Code
############################################################

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

############################################################
# JetBrains Rider
############################################################

.idea/
*.sln.iml

############################################################
# Test Results
############################################################

TestResults/
*.trx
*.coverage
*.coveragexml

############################################################
# NuGet
############################################################

packages/
*.nupkg
*.snupkg
.nuget/
project.assets.json
project.nuget.cache

############################################################
# ASP.NET Core
############################################################

appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

############################################################
# Entity Framework
############################################################

*.dbmdl

############################################################
# Resharper
############################################################

_ReSharper*/
*.DotSettings.user

############################################################
# DotCover
############################################################

*.dotCover

############################################################
# BenchmarkDotNet
############################################################

BenchmarkDotNet.Artifacts/

############################################################
# Node (if React/Angular/Vue is added later)
############################################################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################################################
# Docker
############################################################

docker-compose.override.yml

############################################################
# OS Files
############################################################

.DS_Store
Thumbs.db
Desktop.ini

############################################################
# Temporary Files
############################################################

*.tmp
*.temp
*.bak
*.swp
*.orig

############################################################
# Logs
############################################################

*.log

############################################################
# Environment Files
############################################################

.env
.env.*

############################################################
# Secrets
############################################################

secrets.json
